# ====================================
# Alpha Vantage API Settings
# ====================================
ALPHA_VANTAGE_API_KEY=your_api_key_here

# ====================================
# File Paths
# ====================================
# Path to transactions Excel file (relative to project root)
XLSX_PATH=data/operations.xlsx

# ====================================
# Logging Configuration
# ====================================
# Log file path (use 'console' for console-only logging)
LOG_FILE=logs/app.log

# Log rotation settings
LOG_MAX_SIZE=5  # MB
LOG_BACKUP_COUNT=3

# ====================================
# Application Settings
# ====================================
# Default currency for reports (RUB, USD, EUR)
DEFAULT_CURRENCY=RUB

# Threshold for big transactions (in RUB)
BIG_TRANSACTION_LIMIT=10000

# Date format for reports
DATE_FORMAT=%d.%m.%Y

# ====================================
# API Endpoints
# ====================================
CBR_API_URL=https://www.cbr-xml-daily.ru/daily_json.js
STOCK_API_URL=https://www.alphavantage.co/query